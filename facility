<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Addis Excellence Academy | Primary & High School</title>
    <!-- Modern Fonts -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #003366; /* Formal Blue */
            --sky-blue: #00A3FF;     /* Energetic Blue */
            --gold: #f9cc0b;
            --gold:  #f9cc0b;
            ---gold:  #f9cc0b;
            --white: #ffffff;
            --soft-bg: #f8fafc;
            --glass: rgba(255, 255, 255, 0.9);
        }

        /* Basic Setup */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; scroll-behavior: smooth; }
        body { background: var(--soft-bg); color: #333; overflow-x: hidden; }
        h1, h2, h3, .logo { font-family: 'Montserrat', sans-serif; }

        /* Navigation */
        nav {
            background: var(--glass);
            backdrop-filter: blur(10px);
            padding: 15px 5%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 1000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        .logo { font-size: 1.5rem; color: var(--primary-blue); font-weight: 800; }
        .nav-links { display: flex; list-style: none; }
        .nav-links li { margin-left: 20px; }
        .nav-links a { text-decoration: none; color: var(--primary-blue); font-weight: 600; font-size: 0.9rem; transition: 0.3s; }
        .nav-links a:hover { color: var(--sky-blue); }

        /* Hero Section */
        .hero {
            height: 80vh;
            background: linear-gradient(rgba(0,51,102,0.6), rgba(0,51,102,0.6)), 
                        url('https://images.unsplash.com');
            background-size: cover; background-position: center;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            color: white; text-align: center; padding: 0 20px;
        }
        .hero h1 { font-size: 4rem; margin-bottom: 10px; }
        .hero p { font-size: 1.3rem; max-width: 800px; margin-bottom: 30px; }

        /* General Section Layout */
        section { padding: 80px 5%; }
        .section-title { text-align: center; margin-bottom: 50px; }
        .section-title h2 { font-size: 2.5rem; color: var(--primary-blue); text-transform: uppercase; }
        .divider { width: 100px; height: 5px; background: var(--ethiopia-gold); margin: 10px auto; border-radius: 5px; }

        /* Facility Cards Grid */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }
        .card {
            background: var(--white);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: 0.4s;
            border-bottom: 5px solid transparent;
        }
        .card:hover { transform: translateY(-10px); border-bottom: 5px solid var(--sky-blue); }
        .card-img { height: 200px; width: 100%; object-fit: cover; }
        .card-content { padding: 25px; }
        .card-tag { background: var(--primary-blue); color: white; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: bold; margin-bottom: 10px; display: inline-block; }
        .card h3 { color: var(--primary-blue); margin-bottom: 10px; }

        /* Sports Complex (Unique Layout) */
        .sports-strip { background: var(--primary-blue); color: white; padding: 60px 5%; }
        .sports-grid { display: flex; flex-wrap: wrap; justify-content: space-around; text-align: center; gap: 20px; }
        .sport-item i { font-size: 2.5rem; color: var(--ethiopia-gold); display: block; margin-bottom: 10px; }

        /* Admin/Staff Section */
        .staff-section { background: #eef2f7; padding: 80px 5%; }

        /* Ethiopian Spirit Strip */
        .ethio-spirit { height: 15px; display: flex; }
        .green { flex:1; background: var(--ethiopia-green); }
        .yellow { flex:1; background: var(--ethiopia-gold); }
        .red { flex:1; background: var(--ethiopia-red); }

        /* Footer */
        footer { background: #011222; color: #fff; padding: 80px 5% 20px; }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-bottom: 40px; }
        .footer-col h4 { margin-bottom: 20px; border-left: 4px solid var(--ethiopia-gold); padding-left: 10px; }
        .footer-bottom { border-top: 1px solid #222; padding-top: 20px; text-align: center; font-size: 0.8rem; color: #777; }
    </style>
</head>
<body>

    <nav>
        <a href="#" class="logo">ADDIS ACADEMY</a>
        <ul class="nav-links">
            <li><a href="#primary">Primary</a></li>
            <li><a href="#highschool">High School</a></li>
            <li><a href="#sports">Sports & Arts</a></li>
            <li><a href="#administration">Administration</a></li>
            <li><a href="#spiritual">Campus Life</a></li>
        </ul>
    </nav>

    <header class="hero">
