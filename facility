    <footer>
        <div class="footer-grid">
            <div class="footer-col">
                <h4 style="color:white;">Addis Academy</h4>
                <p>Addis Ababa, Ethiopia</p>
                <p>Leading education through excellence and spirit.</p>
            </div>
            <div class="footer-col">
                <h4 style="color:white;">Quick Links</h4>
                <p>Admissions</p>
